<!doctype html>
<html lang="{{ meta.lang or 'en' }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ meta.title }}</title>
<style>{{ magazine_css }}</style>
<style>{{ highlight_light_css }}</style>
<style>@media (prefers-color-scheme: dark) { {{ highlight_dark_css }} }
[data-theme="dark"] { {{ highlight_dark_css }} }
[data-theme="light"] { {{ highlight_light_css }} }
</style>
</head>
<body>

<header class="topbar">
  <div class="topbar__title">{{ meta.title }}</div>
  <button class="topbar__btn" id="theme-toggle" title="Toggle dark mode">◐</button>
  <button class="topbar__btn" id="skim-mode-top" title="Collapse sections for quick skim">Skim</button>
  <div class="topbar__progress" id="progress-bar"></div>
</header>

<div class="layout">

  <aside class="toc">
    <div class="toc__title">Contents</div>
    <ul class="toc__list">
      {% for s in meta.sections %}
      <li class="toc__item" data-section-id="{{ s.id }}">
        <span class="toc__icon" title="{{ s.type }}">{{ icons.get(s.type, '·') }}</span>
        <a href="#{{ s.id }}" class="toc__link">{{ s.heading }}</a>
        <span class="toc__stars" title="importance">{{ '★' * s.importance }}</span>
        <span class="toc__time">{{ s.estimated_minutes }}m</span>
      </li>
      {% endfor %}
    </ul>
  </aside>

  <main class="article">

    <section class="hero">
      <div class="hero__label">TL;DR</div>
      <h1 class="hero__title">{{ meta.title }}</h1>
      {% if hero_image_html %}
      <figure class="hero__image">
        {{ hero_image_html | safe }}
        <button type="button" class="hero__image-zoom" id="hero-image-zoom" title="Fullscreen" aria-label="View fullscreen">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
            <path d="M3 3h4v1.5H4.5V7H3V3zm6 0h4v4h-1.5V4.5H9V3zm4 6v4H9v-1.5h2.5V9H13zM7 13H3V9h1.5v2.5H7V13z"/>
          </svg>
        </button>
      </figure>
      {% endif %}
      <p class="hero__tldr">{{ meta.tldr }}</p>
      <div class="hero__meta">
        <span class="hero__meta-item">⏱ {{ meta.estimated_read_minutes }} min read</span>
        <span class="hero__meta-item">📑 {{ meta.sections | length }} sections</span>
        {% if meta.lang %}<span class="hero__meta-item">🌐 {{ meta.lang }}</span>{% endif %}
        <button class="hero__expand-btn" id="skim-mode-hero" title="Toggle skim mode">Skim mode</button>
      </div>
    </section>

    {% for s in section_blocks %}
    <article class="section section--{{ s.meta.type }}" id="{{ s.meta.id }}" data-importance="{{ s.meta.importance }}">
      <h{{ s.meta.level }} class="section__heading section__heading--{{ s.meta.level }}">
        <span class="section__icon">{{ icons.get(s.meta.type, '·') }}</span>
        <span class="section__title-text">{{ s.meta.heading }}</span>
        <span class="section__stars">{{ '★' * s.meta.importance }}</span>
        <span class="section__time">{{ s.meta.estimated_minutes }} min</span>
      </h{{ s.meta.level }}>

      {% if s.meta.summary %}
      <p class="section__overview">{{ s.meta.summary }}</p>
      {% endif %}

      {% if s.meta.must_read_quotes %}
      <aside class="must-read">
        <span class="must-read__label">Must read</span>
        <ul>
          {% for q in s.meta.must_read_quotes %}<li>{{ q }}</li>{% endfor %}
        </ul>
      </aside>
      {% endif %}

      {% for c in s.callouts %}
      <div class="callout callout--{{ c.level }}">
        <span class="callout__icon">{{ callout_icons[c.level] }}</span>
        <div class="callout__body">{{ c.text }}</div>
      </div>
      {% endfor %}

      <div class="section__body prose">
        {{ s.html | safe }}
        {% for d in s.diagrams %}
        <figure class="mermaid-wrap">
          <pre class="mermaid">{{ d.mermaid_code }}</pre>
          {% if d.title %}<figcaption class="mermaid-wrap__caption">{{ d.title }}</figcaption>{% endif %}
        </figure>
        {% endfor %}
      </div>
    </article>
    {% endfor %}

    {% if meta.next_actions %}
    <section class="next-actions">
      <h2 class="next-actions__title">Next actions</h2>
      <ul>
        {% for a in meta.next_actions %}<li>{{ a }}</li>{% endfor %}
      </ul>
    </section>
    {% endif %}

    {% if meta.concepts %}
    <section class="glossary">
      <h2 class="glossary__title">Glossary</h2>
      <dl>
        {% for c in meta.concepts %}
        <dt id="glossary-{{ loop.index }}">{{ c.term }}</dt>
        <dd>
          {{ c.plain_explanation }}
          {% if c.analogy %}<br><em style="opacity:.85">Analogy: {{ c.analogy }}</em>{% endif %}
        </dd>
        {% endfor %}
      </dl>
    </section>
    {% endif %}

  </main>
</div>

<div class="floating">
  <button id="back-to-top" title="Back to top">↑</button>
</div>

{% if include_mermaid %}
<script>{{ mermaid_js }}</script>
<script>
  (function() {
    const isDark = matchMedia('(prefers-color-scheme: dark)').matches
      || document.documentElement.dataset.theme === 'dark';
    mermaid.initialize({ startOnLoad: true, theme: isDark ? 'dark' : 'default', securityLevel: 'strict' });
  })();
</script>
{% endif %}

{% if include_highlight %}
<script>{{ highlight_js }}</script>
<script>hljs.highlightAll();</script>
{% endif %}

<script>
(function () {
  // theme toggle
  const root = document.documentElement;
  const themeBtn = document.getElementById('theme-toggle');
  const stored = localStorage.getItem('mh-theme');
  if (stored) root.dataset.theme = stored;
  themeBtn.addEventListener('click', () => {
    const cur = root.dataset.theme || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = cur === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('mh-theme', next);
  });

  // skim mode: collapses sections to heading + overview only.
  // Default = full blog flow (sections expanded).
  const body = document.body;
  function setSkim(on) {
    body.dataset.skim = on ? '1' : '';
    // Reset per-section expansion when toggling
    document.querySelectorAll('.section').forEach(s => s.classList.remove('is-expanded'));
    const topBtn = document.getElementById('skim-mode-top');
    const heroBtn = document.getElementById('skim-mode-hero');
    if (topBtn) topBtn.textContent = on ? 'Read all' : 'Skim';
    if (heroBtn) heroBtn.textContent = on ? 'Expand all sections' : 'Skim mode';
  }
  let skimOn = false;
  ['skim-mode-top', 'skim-mode-hero'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('click', () => { skimOn = !skimOn; setSkim(skimOn); });
  });
  // In skim mode, clicking a section heading reveals just that section's body.
  document.querySelectorAll('.section__heading').forEach(h => {
    h.addEventListener('click', () => {
      if (body.dataset.skim === '1') {
        h.closest('.section').classList.toggle('is-expanded');
      }
    });
  });

  // copy code
  document.querySelectorAll('.code-block__copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const pre = btn.closest('.code-block').querySelector('pre code, pre');
      try {
        await navigator.clipboard.writeText(pre.innerText);
        btn.classList.add('copied');
        const orig = btn.textContent;
        btn.textContent = '✓ Copied';
        setTimeout(() => { btn.classList.remove('copied'); btn.textContent = orig; }, 1500);
      } catch (e) {}
    });
  });

  // collapse long code blocks
  document.querySelectorAll('.code-block').forEach(block => {
    const pre = block.querySelector('pre');
    if (pre && pre.innerText.split('\n').length > 30) {
      block.classList.add('is-collapsed');
      const btn = document.createElement('button');
      btn.className = 'code-block__expand';
      btn.addEventListener('click', () => block.classList.toggle('is-collapsed'));
      block.appendChild(btn);
    }
  });

  // back to top
  document.getElementById('back-to-top').addEventListener('click', () =>
    window.scrollTo({ top: 0, behavior: 'smooth' })
  );

  // hero image fullscreen
  const zoomBtn = document.getElementById('hero-image-zoom');
  if (zoomBtn) {
    zoomBtn.addEventListener('click', () => {
      const fig = zoomBtn.closest('.hero__image');
      const fsEl = document.fullscreenElement || document.webkitFullscreenElement;
      if (fsEl) {
        (document.exitFullscreen || document.webkitExitFullscreen).call(document);
      } else {
        (fig.requestFullscreen || fig.webkitRequestFullscreen).call(fig);
      }
    });
  }

  // progress bar + active TOC
  const bar = document.getElementById('progress-bar');
  const tocItems = [...document.querySelectorAll('.toc__item')];
  const sections = [...document.querySelectorAll('.section')];
  function onScroll() {
    const h = document.documentElement;
    const pct = (h.scrollTop) / (h.scrollHeight - h.clientHeight) * 100;
    bar.style.width = Math.min(100, Math.max(0, pct)) + '%';
    let active = null;
    for (const s of sections) {
      if (s.getBoundingClientRect().top < 120) active = s.id;
    }
    tocItems.forEach(it => it.classList.toggle('toc__item--active', it.dataset.sectionId === active));
  }
  document.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>

</body>
</html>
